{
  "title": "OpenTrust SIP — Redress Tracker",
  "version": 1,
  "panels": [
    {
      "title": "Open Redress Requests",
      "type": "stat",
      "targets": [
        {
          "expr": "opentrust_redress_open_total"
        }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 }
    },
    {
      "title": "Resolution Time (p95)",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(opentrust_trust_redress_time_bucket[7d]))"
        }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 }
    },
    {
      "title": "Redress Requests Created vs Resolved",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(opentrust_redress_created_total[24h])",
          "legendFormat": "Created"
        },
        {
          "expr": "rate(opentrust_redress_resolved_total[24h])",
          "legendFormat": "Resolved"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    }
  ]
}
